# Deployment Environment Variables
# Copy this file to .env and fill in your values

# Private key (DO NOT COMMIT - Add to .env separately)
# PRIVATE_KEY=0x...

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Base Mainnet RPC URL
BASE_RPC=https://mainnet.base.org

# VyoRouter address (after deployment)
VYOROUTER_ADDRESS=0x...

# Chainlink Automation Registry (Base Sepolia)
# Get from https://automation.chain.link/
KEEPER_REGISTRY_ADDRESS=0x...

# WalletConnect Project ID (for frontend)
PUBLIC_WALLET_CONNECT_PROJECT_ID=your-project-id
