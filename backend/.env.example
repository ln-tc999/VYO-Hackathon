# Vyo Apps - Environment Configuration

# ============================================
# SERVER CONFIG
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# YO SDK CONFIG - IMPORTANT FOR HACKATHON!
# ============================================

# Set to 'true' for HACKATHON DEMO - Real YO SDK transactions
# Set to 'false' for development with mock data
USE_LIVE_SDK=false

# Chain ID: 8453 = Base Mainnet, 1 = Ethereum, 42161 = Arbitrum
YO_CHAIN_ID=8453

# ============================================
# AI MODELS - OpenRouter (FREE TIER)
# ============================================

# Get free API key from: https://openrouter.ai/keys
# No credit card required for free models!
OPENROUTER_API_KEY=sk-or-v1-...

# Default free model: nvidia/llama-3.1-nemotron-70b-instruct:free
# Fallbacks (auto-switch if primary fails): meta-llama, mistral

# Optional: Direct NVIDIA API (alternative)
# NVIDIA_API_KEY=nvapi-...

# ============================================
# HACKATHON DEMO CHECKLIST
# ============================================

# Before demo, ensure:
# 1. USE_LIVE_SDK=true
# 2. Test wallet has funds on Base
# 3. Demo wallet: 0x... (your test wallet)
# 4. Small test amounts ($1-5) for deposits

# Supported Networks for YO Protocol:
# - Base Mainnet (Chain ID: 8453) ✓ RECOMMENDED - Low gas
# - Ethereum Mainnet (Chain ID: 1) - Higher gas
# - Arbitrum (Chain ID: 42161) - Not yet supported by YO

# ============================================
# DEVELOPMENT ONLY (No DB needed!)
# ============================================

# This project is STATELESS - no database required
# All data stored on blockchain or frontend IndexedDB
