# Vyo Apps - Environment Configuration

# ============================================
# SERVER CONFIG
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# YO PROTOCOL CONFIG
# ============================================

# Chain ID: 
# 84532 = Base Sepolia Testnet (default for development)
# 8453 = Base Mainnet (production)
YO_CHAIN_ID=84532

# ============================================
# OPERATIONAL MODES
# ============================================

# MODE 1: DEVELOPMENT (Mock user data, Real YO reads)
# - User balances: Mock/simulated
# - Vault data (APY, TVL): Real from YO API
# - Transactions: Mock (no real blockchain calls)
# - Use this for: UI development, testing
DEV_MODE=mock

# MODE 2: PRODUCTION DEMO (Everything real)
# - User balances: Real from blockchain
# - Vault data: Real from YO API
# - Transactions: Real deposit/redeem on-chain
# - Use this for: Production
# DEV_MODE=live

# ============================================
# AI MODELS - OpenRouter (FREE TIER)
# ============================================

# Get free API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ============================================
# MOCK DATA CONFIG (Development Only)
# ============================================

# Mock wallet address for testing (no real crypto needed)
MOCK_WALLET_ADDRESS=0x1234567890123456789012345678901234567890

# Mock initial balances (USD)
MOCK_USDC_BALANCE=1000
MOCK_ETH_BALANCE=0.5

# ============================================
# PRODUCTION CONFIG (Required for DEV_MODE=live)
# ============================================

# Required for real transactions:
# - Wallet with real funds on Base
# - Small amount for testing ($1-5)
# - Gas fees will be deducted from wallet

# ============================================
# NETWORK CONFIG
# ============================================

# RPC URLs (optional - SDK uses defaults)
# Testnet: https://sepolia.base.org
# Mainnet: https://mainnet.base.org
# BASE_RPC=https://sepolia.base.org

# ============================================
# SECURITY
# ============================================

# NEVER commit real private keys!
# For development: Use testnet faucet
# Faucet: https://www.coinbase.com/faucets/base-sepolia-faucet

# ============================================
# TESTNET RESOURCES
# ============================================
# 
# Base Sepolia Testnet:
# - Faucet: https://www.coinbase.com/faucets/base-sepolia-faucet
# - Explorer: https://sepolia.basescan.org
# - Chain ID: 84532
#
# Testnet USDC: 0x036CbD53842c5426634e92b0c9D5eB112A4E1D4D
