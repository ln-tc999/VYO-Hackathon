---
import MainLayout from "../../layouts/MainLayout.astro";
import { PortfolioPositions } from "../../components/portfolio/PortfolioPositions.jsx";
---

<MainLayout title="Portfolio" activePage="portfolio">
<div class="port-wrap">

  <!-- ═══ LEFT ═══ -->
  <div class="port-left">
    
    <!-- Total Value -->
    <div class="wallet-header">
      <div>
        <div class="wallet-label">Total Portfolio Value</div>
        <div class="wallet-value" id="port-total">$0.00</div>
        <div class="wallet-change">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
            <polyline points="17 6 23 6 23 12"/>
          </svg>
          <span id="port-yield">+$0.00</span> yield earned
        </div>
      </div>
      <a href="/dashboard/vaults" class="btn btn-primary">+ Deposit</a>
    </div>

    <!-- Chart -->
    <div class="chart-wrap">
      <div class="chart-tooltip" id="chart-tooltip" style="display:none;">
        <div class="chart-tooltip-dot"></div>
        <div class="chart-tooltip-val" id="chart-tooltip-val"></div>
        <div class="chart-tooltip-date" id="chart-tooltip-date"></div>
      </div>
      <canvas id="chart"></canvas>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-box">
        <div class="stat-label">Yield Earned</div>
        <div class="stat-value lime">$<span id="stat-yield">0.00</span></div>
        <div class="stat-sub">All time</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Current APY</div>
        <div class="stat-value amber"><span id="stat-apy">0.00</span>%</div>
        <div class="stat-sub">Weighted avg</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Active Vaults</div>
        <div class="stat-value"><span id="stat-vaults">0</span></div>
        <div class="stat-sub">Positions</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Best APY</div>
        <div class="stat-value lime"><span id="stat-best">0.00</span>%</div>
        <div class="stat-sub">Top vault</div>
      </div>
    </div>

  </div>

  <!-- ═══ RIGHT ═══ -->
  <div class="port-right">

    <!-- Positions -->
    <div class="section-title-row">
      <div class="section-title-text">Vault Positions</div>
      <div class="section-count" id="position-count">0 vaults</div>
    </div>

    <div class="positions-card" id="positions-card">
      <PortfolioPositions client:only="react" />
    </div>

    <!-- Tips -->
    <div class="tips-card">
      <div class="tips-title">💡 Tips</div>
      <div class="tips-item">
        <span class="tips-dot">•</span>
        <span>Enable auto-compound to reinvest yield automatically</span>
      </div>
      <div class="tips-item">
        <span class="tips-dot">•</span>
        <span>AI scans for better APY opportunities daily</span>
      </div>
      <div class="tips-item">
        <span class="tips-dot">•</span>
        <span>Check AI Agent for rebalancing recommendations</span>
      </div>
    </div>

  </div>
</div>

<style is:global>
  .port-wrap {
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 0;
    min-height: calc(100vh - 80px);
  }

  .port-left {
    padding: 24px;
    border-right: 1px solid rgba(255,255,255,0.07);
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-width: 0;
  }

  .port-right {
    padding: 22px 18px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    overflow-y: auto;
    min-width: 0;
  }

  .wallet-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 12px;
  }

  .wallet-label {
    font-size: 0.8125rem;
    color: #666;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .wallet-value {
    font-size: 2.75rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -2px;
    line-height: 1;
  }

  .wallet-change {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #c8f135;
    margin-top: 6px;
  }

  .wallet-change svg {
    width: 13px;
    height: 13px;
  }

  .chart-wrap {
    background: #111;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 16px 16px 10px;
    position: relative;
    overflow: hidden;
    flex: 1;
    min-height: 200px;
  }

  .chart-tooltip {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: none;
    background: rgba(22, 22, 22, 0.95);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 8px 14px;
    backdrop-filter: blur(8px);
    z-index: 10;
  }

  .chart-tooltip-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #c8f135;
    border: 2px solid #0a0a0a;
    box-shadow: 0 0 12px rgba(200,241,53,0.6);
  }

  .chart-tooltip-val {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .chart-tooltip-date {
    font-size: 0.75rem;
    color: #888;
    padding-left: 8px;
    border-left: 1px solid rgba(255,255,255,0.1);
  }

  canvas#chart {
    width: 100%;
    display: block;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .stat-box {
    background: #111;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 14px;
    text-align: center;
  }

  .stat-label {
    font-size: 0.6875rem;
    color: #666;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .stat-value {
    font-size: 1.375rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.5px;
  }

  .stat-value.lime { color: #c8f135; }
  .stat-value.amber { color: #f59e0b; }

  .stat-sub {
    font-size: 0.625rem;
    color: #555;
    margin-top: 4px;
  }

  .section-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .section-title-text {
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
  }

  .section-count {
    font-size: 0.75rem;
    color: #666;
    font-weight: 500;
  }

  .positions-card {
    background: #111;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    overflow: hidden;
  }

  .position-row {
    display: grid;
    grid-template-columns: 44px 1fr 90px 110px;
    gap: 12px;
    padding: 14px 18px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: background 0.15s;
  }

  .position-row:hover {
    background: rgba(255,255,255,0.02);
  }

  .position-row:last-child {
    border-bottom: none;
  }

  .position-logo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1a1a1a;
    object-fit: cover;
  }

  .position-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .position-symbol {
    font-weight: 700;
    font-size: 0.9375rem;
    color: #fff;
  }

  .position-chain {
    font-size: 0.6875rem;
    color: #666;
    margin-top: 2px;
  }

  .position-apy {
    font-weight: 700;
    font-size: 0.9375rem;
    color: #c8f135;
    text-align: right;
  }

  .position-value {
    font-weight: 600;
    font-size: 0.9375rem;
    color: #fff;
    text-align: right;
  }

  .tips-card {
    background: rgba(200,241,53,0.03);
    border: 1px solid rgba(200,241,53,0.1);
    border-radius: 14px;
    padding: 16px;
  }

  .tips-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #c8f135;
    margin-bottom: 12px;
  }

  .tips-item {
    display: flex;
    gap: 8px;
    font-size: 0.75rem;
    color: #888;
    line-height: 1.4;
    margin-bottom: 10px;
  }

  .tips-item:last-child {
    margin-bottom: 0;
  }

  .tips-dot {
    color: #c8f135;
    font-weight: 700;
  }

  .empty-state {
    padding: 48px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }

  .empty-text {
    color: #666;
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .port-wrap {
      grid-template-columns: 1fr;
    }
    .port-left {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .stats-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .port-left {
      padding: 16px;
    }
    .port-right {
      padding: 16px;
    }
    .wallet-value {
      font-size: 2rem;
    }
    .position-row {
      grid-template-columns: 40px 1fr 80px;
    }
    .position-apy {
      display: none;
    }
  }
</style>

<script>
const API = "/api";
const fmt = (n: number) => new Intl.NumberFormat("en-US",{style:"currency",currency:"USD"}).format(n);

// Chart
const canvas = document.getElementById("chart") as HTMLCanvasElement;
const ctx = canvas.getContext("2d")!;

function generateMockData() {
  const count = 90;
  const data: number[] = [];
  let val = 10000;
  for(let i = 0; i < count; i++){
    val += (Math.random() - 0.45) * 200;
    val = Math.max(5000, Math.min(20000, val));
    data.push(val);
  }
  return data;
}

function drawChart(data: number[]) {
  const dpr = window.devicePixelRatio || 1;
  const W = canvas.parentElement!.clientWidth - 32;
  const H = 220;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + "px";
  canvas.style.height = H + "px";
  ctx.scale(dpr, dpr);

  const min = Math.min(...data);
  const max = Math.max(...data);
  const rng = max - min || 1;
  const padY = 20;

  const px = (i: number) => (i / (data.length - 1)) * W;
  const py = (v: number) => H - padY - ((v - min) / rng) * (H - padY * 2);

  // Grid
  ctx.strokeStyle = "rgba(255,255,255,0.03)";
  ctx.lineWidth = 1;
  for(let i = 0; i <= 20; i++){
    const x = (i / 20) * W;
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }

  // Gradient
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, "rgba(200,241,53,0.25)");
  grad.addColorStop(0.5, "rgba(200,241,53,0.08)");
  grad.addColorStop(1, "rgba(200,241,53,0)");
  ctx.beginPath();
  ctx.moveTo(px(0), H);
  data.forEach((v, i) => ctx.lineTo(px(i), py(v)));
  ctx.lineTo(px(data.length - 1), H);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.shadowColor = "rgba(200,241,53,0.5)";
  ctx.shadowBlur = 8;
  ctx.beginPath();
  ctx.strokeStyle = "#c8f135";
  ctx.lineWidth = 2.5;
  ctx.lineJoin = "round";
  ctx.lineCap = "round";
  data.forEach((v, i) => i === 0 ? ctx.moveTo(px(i), py(v)) : ctx.lineTo(px(i), py(v)));
  ctx.stroke();
  ctx.shadowBlur = 0;
}

drawChart(generateMockData());
window.addEventListener("resize", () => drawChart(generateMockData()));
</script>
</MainLayout>
