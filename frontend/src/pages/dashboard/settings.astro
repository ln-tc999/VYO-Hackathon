---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Portfolio" activePage="settings">
<style>
  .port-wrap { padding: 28px 28px; width: 100%; box-sizing: border-box; }

  /* Header */
  .port-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 28px; }
  .port-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.5px; }
  .port-subtitle { font-size: 0.8125rem; color: #555; margin-top: 4px; }
  .port-updated { font-size: 0.75rem; color: #555; text-align: right; }

  /* Summary cards row */
  .summary-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
  .sum-card {
    background: #111; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 18px 20px;
  }
  .sum-label { font-size: 0.6875rem; color: #555; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .sum-val { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.5px; }
  .sum-val.pos { color: #c8f135; }
  .sum-val.neg { color: #ef4444; }
  .sum-val.white { color: #fff; }
  .sum-sub { font-size: 0.6875rem; color: #555; margin-top: 4px; }
  .sum-sub.pos { color: #c8f135; }
  .sum-sub.neg { color: #ef4444; }

  /* 2-col body */
  .port-body { display: grid; grid-template-columns: 1fr 340px; gap: 16px; }

  /* Allocation donut + legend */
  .alloc-card {
    background: #111; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 22px 24px;
  }
  .card-title { font-size: 0.9375rem; font-weight: 700; margin-bottom: 18px; }

  .alloc-inner { display: flex; align-items: center; gap: 28px; }
  .donut-wrap { position: relative; flex-shrink: 0; width: 140px; height: 140px; }
  .donut-wrap svg { width: 140px; height: 140px; }
  .donut-center {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .donut-center-val { font-size: 1.125rem; font-weight: 800; color: #fff; letter-spacing: -0.5px; }
  .donut-center-label { font-size: 0.625rem; color: #555; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }

  .alloc-legend { flex: 1; display: flex; flex-direction: column; gap: 10px; }
  .legend-row { display: flex; align-items: center; gap: 10px; }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .legend-name { font-size: 0.8125rem; color: #aaa; flex: 1; }
  .legend-pct { font-size: 0.8125rem; font-weight: 700; color: #fff; }
  .legend-val { font-size: 0.75rem; color: #555; min-width: 60px; text-align: right; }

  /* Goals progress */
  .goals-card {
    background: #111; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 22px 24px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .goal-row {}
  .goal-row-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .goal-row-name { font-size: 0.8125rem; font-weight: 600; }
  .goal-row-pct { font-size: 0.8125rem; font-weight: 700; color: #c8f135; }
  .goal-row-bar { height: 5px; background: rgba(255,255,255,0.07); border-radius: 999px; overflow: hidden; margin-bottom: 4px; }
  .goal-row-fill { height: 100%; border-radius: 999px; background: #c8f135; }
  .goal-row-meta { display: flex; justify-content: space-between; font-size: 0.6875rem; color: #555; }

  /* Positions table */
  .positions-card {
    background: #111; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 22px 24px;
    margin-top: 16px;
  }
  .pos-table { width: 100%; border-collapse: collapse; }
  .pos-table th {
    font-size: 0.6875rem; font-weight: 600; color: #555;
    text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0 0 12px; text-align: left;
  }
  .pos-table th:not(:first-child) { text-align: right; }
  .pos-table td { padding: 12px 0; border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.8125rem; }
  .pos-table td:not(:first-child) { text-align: right; }
  .pos-vault-name { font-weight: 600; color: #fff; }
  .pos-vault-sub { font-size: 0.6875rem; color: #555; margin-top: 2px; }
  .pos-apy { color: #c8f135; font-weight: 700; }
  .pos-gain { color: #c8f135; font-weight: 600; }
  .pos-badge {
    display: inline-block; padding: 2px 8px; border-radius: 999px;
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .pos-badge.active { background: rgba(200,241,53,0.12); color: #c8f135; }

  @media (max-width: 900px) {
    .summary-row { grid-template-columns: repeat(2,1fr); }
    .port-body { grid-template-columns: 1fr; }
  }
</style>

<div class="port-wrap">

  <!-- Header -->
  <div class="port-header">
    <div>
      <div class="port-title">Portfolio</div>
      <div class="port-subtitle">Your complete DeFi position overview</div>
    </div>
    <div class="port-updated" id="port-updated">Updated just now</div>
  </div>

  <!-- Summary row -->
  <div class="summary-row">
    <div class="sum-card">
      <div class="sum-label">Total Value</div>
      <div class="sum-val white" id="p-total">$0.00</div>
      <div class="sum-sub" id="p-total-sub">DeFi + TradFi</div>
    </div>
    <div class="sum-card">
      <div class="sum-label">DeFi Balance</div>
      <div class="sum-val white" id="p-defi">$0.00</div>
      <div class="sum-sub pos" id="p-defi-sub">Across vaults</div>
    </div>
    <div class="sum-card">
      <div class="sum-label">Total Yield Earned</div>
      <div class="sum-val pos" id="p-yield">$0.00</div>
      <div class="sum-sub pos" id="p-yield-sub">All time</div>
    </div>
    <div class="sum-card">
      <div class="sum-label">Monthly Yield</div>
      <div class="sum-val pos" id="p-monthly">$0.00</div>
      <div class="sum-sub" id="p-monthly-sub">Projected</div>
    </div>
  </div>

  <!-- Body: allocation + goals -->
  <div class="port-body">

    <!-- Allocation donut -->
    <div class="alloc-card">
      <div class="card-title">Vault Allocation</div>
      <div class="alloc-inner">
        <div class="donut-wrap">
          <svg viewBox="0 0 140 140" id="donut-svg"></svg>
          <div class="donut-center">
            <div class="donut-center-val" id="donut-val">$0</div>
            <div class="donut-center-label">DeFi</div>
          </div>
        </div>
        <div class="alloc-legend" id="alloc-legend"></div>
      </div>
    </div>

    <!-- Goals progress -->
    <div class="goals-card">
      <div class="card-title">Goals Progress</div>
      <div id="goals-list">
        <div style="color:#555;font-size:0.8125rem;text-align:center;padding:16px;">Loading...</div>
      </div>
    </div>

  </div>

  <!-- Positions table -->
  <div class="positions-card">
    <div class="card-title">Active Positions</div>
    <table class="pos-table">
      <thead>
        <tr>
          <th>Vault</th>
          <th>Balance</th>
          <th>APY</th>
          <th>Yield Earned</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="positions-body">
        <tr><td colspan="5" style="text-align:center;color:#555;padding:24px 0;">Loading...</td></tr>
      </tbody>
    </table>
  </div>

</div>
</MainLayout>

<script>
const API = "/api";
const fmt = (n: number) => new Intl.NumberFormat("en-US",{style:"currency",currency:"USD"}).format(n);
const fmtK = (n: number) => n >= 1000 ? `$${(n/1000).toFixed(1)}K` : fmt(n);

const VAULT_COLORS = ["#c8f135","#3b82f6","#a78bfa","#f59e0b","#06b6d4","#ec4899","#22c55e"];
const VAULT_APYS: Record<string,number> = {
  yoUSD: 5.2, yoETH: 8.4, yoBTC: 7.1, yoGOLD: 4.8,
  yoUSDT: 5.0, yoEUR: 4.2, default: 6.0
};

// ── Donut chart ──────────────────────────────────────────
function drawDonut(segments: {pct: number; color: string}[]) {
  const svg = document.getElementById("donut-svg")!;
  const cx = 70, cy = 70, r = 54, stroke = 18;
  const circumference = 2 * Math.PI * r;
  let offset = -circumference * 0.25; // start at top

  const paths = segments.map(s => {
    const dash = (s.pct / 100) * circumference;
    const gap  = circumference - dash;
    const el = `<circle
      cx="${cx}" cy="${cy}" r="${r}"
      fill="none"
      stroke="${s.color}"
      stroke-width="${stroke}"
      stroke-dasharray="${dash} ${gap}"
      stroke-dashoffset="${-offset}"
      style="transition: stroke-dasharray 0.5s ease;"
    />`;
    offset += dash;
    return el;
  });

  // background ring
  svg.innerHTML = `
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="${stroke}"/>
    ${paths.join("")}
  `;
}

// ── Load data ────────────────────────────────────────────
async function loadPortfolio() {
  try {
    const [dashRes, goalsRes] = await Promise.all([
      fetch(`${API}/dashboard`),
      fetch(`${API}/goals`),
    ]);
    const dash = await dashRes.json();
    const goalsData = await goalsRes.json();

    if (!dash.success) return;
    const d = dash.data;

    // Summary cards
    document.getElementById("p-total")!.textContent = fmt(d.totalNetWorth);
    document.getElementById("p-total-sub")!.textContent = `DeFi ${fmtK(d.defiBalance)} + TradFi ${fmtK(d.tradFiBalance)}`;
    document.getElementById("p-defi")!.textContent = fmt(d.defiBalance);
    document.getElementById("p-defi-sub")!.textContent = `${d.activeVaults} active vault${d.activeVaults !== 1 ? "s" : ""}`;
    document.getElementById("p-yield")!.textContent = fmt(d.totalYieldEarned);
    document.getElementById("p-yield-sub")!.textContent = `+${((d.totalYieldEarned / (d.defiBalance || 1)) * 100).toFixed(2)}% return`;
    document.getElementById("p-monthly")!.textContent = fmt(d.yieldMonth);
    document.getElementById("p-monthly-sub")!.textContent = `~${fmt(d.yieldMonth * 12)} / year`;
    document.getElementById("donut-val")!.textContent = fmtK(d.defiBalance);

    // Build vault aggregation from goals
    const goals = goalsData.success ? goalsData.data : [];
    const vaultMap: Record<string, {name: string; balance: number; color: string; idx: number}> = {};
    let colorIdx = 0;

    goals.forEach((g: any) => {
      g.vaultAllocations.forEach((a: any) => {
        if (!vaultMap[a.vaultId]) {
          vaultMap[a.vaultId] = { name: a.vaultName, balance: 0, color: VAULT_COLORS[colorIdx++ % VAULT_COLORS.length], idx: colorIdx };
        }
        vaultMap[a.vaultId].balance += a.currentBalance;
      });
    });

    const vaults = Object.entries(vaultMap)
      .map(([id, v]) => ({ id, ...v }))
      .sort((a, b) => b.balance - a.balance);

    const total = vaults.reduce((s, v) => s + v.balance, 0) || 1;

    // Donut
    drawDonut(vaults.map(v => ({ pct: (v.balance / total) * 100, color: v.color })));

    // Legend
    const legend = document.getElementById("alloc-legend")!;
    legend.innerHTML = vaults.map(v => `
      <div class="legend-row">
        <div class="legend-dot" style="background:${v.color};"></div>
        <span class="legend-name">${v.name}</span>
        <span class="legend-pct">${((v.balance / total) * 100).toFixed(0)}%</span>
        <span class="legend-val">${fmtK(v.balance)}</span>
      </div>`).join("");

    // Goals list
    const goalsList = document.getElementById("goals-list")!;
    if (d.goalSummaries.length === 0) {
      goalsList.innerHTML = `<div style="color:#555;font-size:0.8125rem;text-align:center;padding:16px;">No goals yet</div>`;
    } else {
      goalsList.innerHTML = d.goalSummaries.map((g: any) => {
        const deadline = new Date(g.deadline).toLocaleDateString("en-US",{month:"short",year:"numeric"});
        return `
          <div class="goal-row">
            <div class="goal-row-top">
              <span class="goal-row-name">${g.name}</span>
              <span class="goal-row-pct">${g.progressPercent}%</span>
            </div>
            <div class="goal-row-bar">
              <div class="goal-row-fill" style="width:${g.progressPercent}%;"></div>
            </div>
            <div class="goal-row-meta">
              <span>${fmt(g.currentAmount)} of ${fmt(g.targetAmount)}</span>
              <span>Due ${deadline}</span>
            </div>
          </div>`;
      }).join("");
    }

    // Positions table
    const tbody = document.getElementById("positions-body")!;
    if (vaults.length === 0) {
      tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;color:#555;padding:24px 0;">No positions found</td></tr>`;
    } else {
      tbody.innerHTML = vaults.map(v => {
        const apy = VAULT_APYS[v.id] ?? VAULT_APYS.default;
        const yieldEarned = v.balance * 0.038;
        return `
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:32px;height:32px;border-radius:50%;background:${v.color}22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <div style="width:10px;height:10px;border-radius:50%;background:${v.color};"></div>
                </div>
                <div>
                  <div class="pos-vault-name">${v.name}</div>
                  <div class="pos-vault-sub">${v.id.toUpperCase()}</div>
                </div>
              </div>
            </td>
            <td style="font-weight:700;">${fmt(v.balance)}</td>
            <td class="pos-apy">${apy.toFixed(1)}%</td>
            <td class="pos-gain">+${fmt(yieldEarned)}</td>
            <td><span class="pos-badge active">Active</span></td>
          </tr>`;
      }).join("");
    }

    // Updated time
    document.getElementById("port-updated")!.textContent = `Updated ${new Date().toLocaleTimeString("en-US",{hour:"2-digit",minute:"2-digit"})}`;

  } catch(err) {
    console.error("Portfolio load failed:", err);
  }
}

loadPortfolio();
</script>
