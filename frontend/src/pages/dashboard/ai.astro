---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="AI Agent" activePage="ai">
<div style="padding:28px 24px;">

  <div class="page-header">
    <h1 class="page-title">AI Agent</h1>
    <p class="page-subtitle">Every decision is explained and requires your approval before execution.</p>
  </div>

  <!-- Actions bar -->
  <div style="display:flex; gap:var(--s3); margin-bottom:var(--s6); flex-wrap:wrap; align-items:center;">
    <button class="btn btn-primary btn-lg" id="scan-btn" onclick="runScan()">
      Run Scan
    </button>
    <div style="display:flex; gap:var(--s2); margin-left:auto;">
      <button class="btn btn-ghost filter-btn active" data-filter="all"             onclick="filterDecisions('all',this)">All</button>
      <button class="btn btn-ghost filter-btn"        data-filter="pending_approval" onclick="filterDecisions('pending_approval',this)">Pending</button>
      <button class="btn btn-ghost filter-btn"        data-filter="executed"         onclick="filterDecisions('executed',this)">Executed</button>
    </div>
  </div>

  <!-- Count -->
  <div class="section-header">
    <h2 class="section-title">Decision Log</h2>
    <span style="font-size:var(--font-xs);color:var(--text-muted);" id="decision-count">0 decisions</span>
  </div>

  <div class="decisions-list" id="decisions-list">
    <div class="card empty-state loading">
      <div class="empty-state-text">Loading decisions...</div>
    </div>
  </div>

</div>
</MainLayout>

<script>
  const API = "/api";
  let allDecisions: any[] = [];
  let currentFilter = "all";

  const fmt = (n) => new Intl.NumberFormat("en-US", { style: "currency", currency: "USD" }).format(n);

  function timeAgo(dateStr) {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    return `${Math.floor(hours / 24)}d ago`;
  }

  function renderDecisions(decisions) {
    const list = document.getElementById("decisions-list");
    const countEl = document.getElementById("decision-count");
    countEl.textContent = `${decisions.length} decision${decisions.length !== 1 ? "s" : ""}`;

    if (decisions.length === 0) {
      list.innerHTML = `
        <div class="card empty-state">
          <div class="empty-state-icon">◈</div>
          <div class="empty-state-text">No decisions yet — run a scan</div>
        </div>`;
      return;
    }

    list.innerHTML = decisions.map(d => {
      const isPending  = d.status === "pending_approval";
      const isExecuted = d.status === "executed";
      const isRejected = d.status === "rejected";

      return `
        <div class="card decision-card ${d.type}">
          <div class="decision-header">
            <div class="decision-type">
              <span class="badge badge-${d.type==='rebalance'?'info':d.type==='risk_alert'?'danger':'success'}">${d.type.replace(/_/g," ")}</span>
              <span class="decision-goal">${d.goalName}</span>
            </div>
            <span class="decision-time">${timeAgo(d.createdAt)}</span>
          </div>

          <div class="decision-action">${d.action}</div>
          <div class="decision-reasoning">${d.reasoning}</div>

          <div class="decision-metrics">
            <div class="metric">
              <div class="metric-label">Expected Gain</div>
              <div class="metric-value positive">${fmt(d.expectedGain)}</div>
            </div>
            <div class="metric">
              <div class="metric-label">Gas Cost</div>
              <div class="metric-value negative">${fmt(d.gasCost)}</div>
            </div>
            <div class="metric">
              <div class="metric-label">Net Benefit</div>
              <div class="metric-value ${d.expectedGain - d.gasCost > 0 ? 'positive' : 'negative'}">${fmt(d.expectedGain - d.gasCost)}</div>
            </div>
          </div>

          ${isPending ? `
            <div class="decision-actions">
              <button class="btn btn-primary" onclick="approveDecision('${d.id}')">Approve & Execute</button>
              <button class="btn btn-ghost"   onclick="rejectDecision('${d.id}')">Dismiss</button>
            </div>` : ""}

          ${isExecuted ? `<div class="decision-status executed">✓ Executed</div>` : ""}
          ${isRejected ? `<div class="decision-status rejected">✕ Dismissed</div>` : ""}
        </div>`;
    }).join("");
  }

  async function loadDecisions() {
    try {
      const res = await fetch(`${API}/ai/decisions`);
      const json = await res.json();
      if (json.success) {
        allDecisions = json.data;
        applyFilter();
      }
    } catch (err) {
      console.error("Failed to load decisions:", err);
    }
  }

  function applyFilter() {
    const filtered = currentFilter === "all"
      ? allDecisions
      : allDecisions.filter(d => d.status === currentFilter);
    renderDecisions(filtered);
  }

  function filterDecisions(filter: string, btn: HTMLElement) {
    currentFilter = filter;
    document.querySelectorAll(".filter-btn").forEach(b => {
      b.classList.remove("btn-primary", "active"); b.classList.add("btn-ghost");
    });
    btn.classList.remove("btn-ghost"); btn.classList.add("btn-primary", "active");
    applyFilter();
  }

  async function runScan() {
    const btn = document.getElementById("scan-btn") as HTMLButtonElement;
    btn.textContent = "Scanning...";
    btn.disabled = true;
    try {
      const res = await fetch(`${API}/ai/rebalance`, { method: "POST" });
      const json = await res.json();
      showToast(json.success && json.data.length > 0
        ? `Found ${json.data.length} new recommendation${json.data.length > 1 ? "s" : ""}`
        : "All looks good — no new recommendations");
      loadDecisions();
    } catch (err) {
      console.error("Scan failed:", err);
    } finally {
      btn.textContent = "Run Scan";
      btn.disabled = false;
    }
  }

  async function approveDecision(id) {
    await fetch(`${API}/ai/decisions/${id}/approve`, { method: "POST" });
    showToast("Decision approved");
    loadDecisions();
  }

  async function rejectDecision(id) {
    await fetch(`${API}/ai/decisions/${id}/reject`, { method: "POST" });
    showToast("Decision dismissed");
    loadDecisions();
  }

  function showToast(msg: string) {
    const t = document.createElement("div");
    t.className = "toast";
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3000);
  }

  loadDecisions();
</script>
