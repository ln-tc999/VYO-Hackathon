---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Dashboard" activePage="dashboard">
<style is:global>
  /* ── 2-col layout ── */
  .dash-wrap {
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 0;
    min-height: calc(100vh - 80px);
    box-sizing: border-box;
  }

  /* ── LEFT ── */
  .dash-left {
    padding: 24px 24px 24px;
    border-right: 1px solid rgba(255,255,255,0.07);
    display: flex; flex-direction: column; gap: 18px;
  }

  /* Wallet header row */
  .wallet-header { display: flex; justify-content: space-between; align-items: flex-start; }
  .wallet-label { font-size: 0.8125rem; color: #666; font-weight: 500; margin-bottom: 4px; }
  .wallet-value { font-size: 2.75rem; font-weight: 800; color: #fff; letter-spacing: -2px; line-height: 1; }
  .wallet-change {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.8125rem; font-weight: 600; color: #c8f135; margin-top: 6px;
  }
  .wallet-change svg { width: 13px; height: 13px; }

  /* Time pills */
  .time-pills { display: flex; gap: 3px; align-self: flex-start; margin-top: 4px; }
  .time-pill {
    padding: 5px 10px; border-radius: 7px;
    font-size: 0.75rem; font-weight: 600; color: #555;
    background: none; border: none; cursor: pointer;
    font-family: var(--font); transition: all 0.15s;
  }
  .time-pill:hover { color: #ccc; background: rgba(255,255,255,0.05); }
  .time-pill.active { background: #c8f135; color: #000; }

  /* Chart */
  .chart-wrap {
    background: #111; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 16px 16px 10px;
    position: relative; overflow: hidden; flex: 1;
  }
  .chart-tooltip {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 8px; pointer-events: none;
  }
  .chart-tooltip-dot {
    width: 11px; height: 11px; border-radius: 50%; background: #c8f135;
    border: 2px solid #0a0a0a; box-shadow: 0 0 8px rgba(200,241,53,0.6);
  }
  .chart-tooltip-val { font-size: 0.875rem; font-weight: 700; color: #fff; }
  canvas#chart { width: 100%; display: block; }

  /* Stats row — 4 equal boxes */
  .stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; }
  .stat-box {
    background: #111; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px; padding: 14px 16px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .stat-box-label {
    font-size: 0.6875rem; color: #555; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .stat-box-val { font-size: 1.125rem; font-weight: 800; letter-spacing: -0.5px; }
  .stat-box-val.pos { color: #c8f135; }
  .stat-box-val.neg { color: #ef4444; }
  .stat-box-sub { font-size: 0.6875rem; font-weight: 500; }
  .stat-box-sub.pos { color: #c8f135; }
  .stat-box-sub.neg { color: #ef4444; }
  .stat-box-sub.muted { color: #555; }

  /* ── RIGHT ── */
  .dash-right {
    padding: 22px 18px;
    display: flex; flex-direction: column; gap: 22px;
    overflow-y: auto;
  }

  /* Risk score */
  .risk-title { font-size: 1.375rem; font-weight: 800; letter-spacing: -0.5px; line-height: 1.2; }
  .risk-bar-wrap { margin: 14px 0 6px; }
  .risk-bar-track {
    width: 100%; height: 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 3px; overflow: hidden;
  }
  .risk-bar-fill {
    height: 100%; border-radius: 3px;
    background: #c8f135;
    transition: width 0.6s ease;
  }
  .risk-labels { display: flex; justify-content: space-between; font-size: 0.6875rem; color: #555; }

  /* Section header */
  .section-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .section-hdr-title { font-size: 0.9375rem; font-weight: 700; }
  .view-all { font-size: 0.8125rem; color: #c8f135; font-weight: 600; text-decoration: none; }
  .view-all:hover { text-decoration: underline; }

  /* ── Transaction 2-col grid ── */
  .txn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

  .txn-card {
    background: #161616;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 16px;
    padding: 13px 13px 13px;
    display: flex; flex-direction: column;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  /* Fill from bottom to top on hover */
  .txn-card::before {
    content: '';
    position: absolute; left: 0; right: 0; bottom: 0;
    height: 0;
    background: rgba(200,241,53,0.08);
    transition: height 0.35s ease;
    z-index: 0;
    border-radius: 16px;
  }
  .txn-card:hover { border-color: rgba(200,241,53,0.35); }
  .txn-card:hover::before { height: 100%; }
  .txn-card > * { position: relative; z-index: 1; }

  /* Lime highlight */
  .txn-card.lime { background: #c8f135; border-color: #c8f135; }
  .txn-card.lime::before { background: rgba(0,0,0,0.08); }
  .txn-card.lime:hover { border-color: #b8e020; }
  .txn-card.lime .txn-type   { color: rgba(0,0,0,0.7); }
  .txn-card.lime .txn-date   { color: rgba(0,0,0,0.45); }
  .txn-card.lime .txn-asset  { color: rgba(0,0,0,0.5); }
  .txn-card.lime .txn-amount { color: #000; }
  .txn-card.lime .txn-status { color: rgba(0,0,0,0.6); }

  /* Icon row */
  .txn-top { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 0; }
  .txn-icon {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    color: #fff;
  }
  .txn-card.lime .txn-icon {
    background: rgba(0,0,0,0.1);
    border-color: rgba(0,0,0,0.15);
    color: #000;
  }
  .txn-meta { display: flex; flex-direction: column; }
  .txn-type { font-size: 0.8125rem; font-weight: 700; color: #fff; line-height: 1.3; }
  .txn-date { font-size: 0.6875rem; color: #555; margin-top: 1px; }

  /* Sparkline — full bleed */
  .txn-spark {
    width: calc(100% + 26px);
    margin: 10px -13px;
    height: 52px; flex-shrink: 0;
  }
  .txn-spark svg { width: 100%; height: 100%; display: block; }

  /* Bottom info */
  .txn-asset  {
    font-size: 0.6875rem; color: #555; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 2px;
  }
  .txn-amount {
    font-size: 1.25rem; font-weight: 800; color: #fff;
    letter-spacing: -0.5px; line-height: 1.1; margin-bottom: 5px;
  }
  .txn-status {
    font-size: 0.6875rem; font-weight: 600;
    display: flex; align-items: center; gap: 4px;
  }
  .txn-status.confirmed { color: #c8f135; }
  .txn-status.pending   { color: #f59e0b; }
  .txn-status.failed    { color: #ef4444; }

  /* Goals mini */
  .goals-mini { display: flex; flex-direction: column; gap: 6px; }
  .goal-mini {
    background: #1a1a1a; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 11px; padding: 11px 13px;
  }
  .goal-mini-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
  .goal-mini-name { font-size: 0.8125rem; font-weight: 600; }
  .goal-mini-pct { font-size: 0.75rem; font-weight: 700; color: #c8f135; }
  .goal-mini-bar { height: 4px; background: rgba(255,255,255,0.07); border-radius: 999px; overflow: hidden; }
  .goal-mini-fill { height: 100%; background: #c8f135; border-radius: 999px; }

  @media (max-width: 960px) {
    .dash-wrap { grid-template-columns: 1fr; }
    .dash-left { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.07); }
    .stats-row { grid-template-columns: repeat(2,1fr); }
  }
</style>

<div class="dash-wrap">

  <!-- ═══ LEFT ═══ -->
  <div class="dash-left">

    <!-- Wallet value + time pills -->
    <div class="wallet-header">
      <div>
        <div class="wallet-label">Wallet Value</div>
        <div class="wallet-value" id="wallet-value">$0.00</div>
        <div class="wallet-change">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          <span id="wallet-change-val">+0%</span>
        </div>
      </div>
      <div class="time-pills">
        {["1h","8h","1d","1w","1m","6m","1y"].map((t) => (
          <button class={`time-pill ${t === "6m" ? "active" : ""}`} data-range={t} onclick="setRange(this)">{t}</button>
        ))}
      </div>
    </div>

    <!-- Chart -->
    <div class="chart-wrap">
      <div class="chart-tooltip" id="chart-tooltip" style="display:none;">
        <div class="chart-tooltip-dot"></div>
        <div class="chart-tooltip-val" id="chart-tooltip-val"></div>
      </div>
      <canvas id="chart"></canvas>
    </div>

    <!-- Stats row -->
    <div class="stats-row">
      <div class="stat-box">
        <div class="stat-box-label">Realized P&L</div>
        <div class="stat-box-val pos" id="s-today">$0.00</div>
        <div class="stat-box-sub pos" id="s-today-pct">+0% Today</div>
      </div>
      <div class="stat-box">
        <div class="stat-box-label">Unrealized P&L</div>
        <div class="stat-box-val neg" id="s-unrealized">$0.00</div>
        <div class="stat-box-sub neg" id="s-unrealized-pct">0% Today</div>
      </div>
      <div class="stat-box">
        <div class="stat-box-label">Projected Growth</div>
        <div class="stat-box-val pos" id="s-projected">$0.00</div>
        <div class="stat-box-sub pos" id="s-projected-pct">+0% Today</div>
      </div>
      <div class="stat-box">
        <div class="stat-box-label">Net Change</div>
        <div class="stat-box-val pos" id="s-net">$0.00</div>
        <div class="stat-box-sub neg" id="s-net-pct">0% Today</div>
      </div>
    </div>

  </div>

  <!-- ═══ RIGHT ═══ -->
  <div class="dash-right">

    <!-- Portfolio Risk Score -->
    <div>
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div class="risk-title">Portfolio<br/>Risk Score</div>
        <div style="text-align:right;">
          <div style="font-size:0.6875rem;color:#555;">Updated:</div>
          <div style="font-size:0.6875rem;color:#555;">Just Now</div>
        </div>
      </div>
      <div class="risk-bar-wrap">
        <div class="risk-bar-track">
          <div class="risk-bar-fill" id="risk-fill" style="width:40%;"></div>
        </div>
      </div>
      <div class="risk-labels"><span>Low Risk</span><span>High Risk</span></div>
    </div>

    <!-- Transactions -->
    <div>
      <div class="section-hdr">
        <span class="section-hdr-title">Transactions</span>
        <a href="/dashboard/goals" class="view-all">View All</a>
      </div>
      <div class="txn-grid" id="txn-grid">
        <div style="grid-column:1/-1;text-align:center;color:#555;font-size:0.8125rem;padding:24px;">Loading...</div>
      </div>
    </div>

    <!-- Goals mini -->
    <div>
      <div class="section-hdr">
        <span class="section-hdr-title">Goals</span>
        <a href="/dashboard/goals" class="view-all">View All</a>
      </div>
      <div class="goals-mini" id="goals-mini">
        <div style="color:#555;font-size:0.8125rem;text-align:center;padding:16px;">Loading...</div>
      </div>
    </div>

  </div>
</div>

<script>
const API = "/api";
const fmt = (n: number) => new Intl.NumberFormat("en-US",{style:"currency",currency:"USD"}).format(n);
const fmtShort = (n: number) => {
  const abs = Math.abs(n);
  const sign = n >= 0 ? "+" : "-";
  if(abs >= 1000) return sign + "$" + (abs/1000).toFixed(1) + "K";
  return sign + fmt(abs);
};

// ── Chart ──────────────────────────────────────────────────
const canvas = document.getElementById("chart") as HTMLCanvasElement;
const ctx = canvas.getContext("2d")!;
let chartData: number[] = [];
let currentRange = "6m";

function generateChartData(range: string): number[] {
  const points: Record<string,number> = { "1h":60,"8h":96,"1d":48,"1w":56,"1m":60,"6m":90,"1y":120 };
  const count = points[range] || 90;
  const base = 27000;
  const data: number[] = [];
  let val = base;
  for(let i = 0; i < count; i++){
    val += (Math.random() - 0.46) * 400;
    val = Math.max(base * 0.7, Math.min(base * 1.6, val));
    data.push(val);
  }
  return data;
}

function drawChart(data: number[], hoverIdx = -1) {
  const dpr = window.devicePixelRatio || 1;
  const W = canvas.parentElement!.clientWidth - 32;
  const H = 280;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + "px";
  canvas.style.height = H + "px";
  ctx.scale(dpr, dpr);

  const min = Math.min(...data);
  const max = Math.max(...data);
  const rng = max - min || 1;
  const padY = 16;

  const px = (i: number) => (i / (data.length - 1)) * W;
  const py = (v: number) => H - padY - ((v - min) / rng) * (H - padY * 2);

  // Vertical grid lines
  ctx.strokeStyle = "rgba(255,255,255,0.04)";
  ctx.lineWidth = 1;
  for(let i = 0; i <= 20; i++){
    const x = (i / 20) * W;
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }

  // Gradient fill
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, "rgba(200,241,53,0.18)");
  grad.addColorStop(1, "rgba(200,241,53,0)");
  ctx.beginPath();
  ctx.moveTo(px(0), H);
  data.forEach((v, i) => ctx.lineTo(px(i), py(v)));
  ctx.lineTo(px(data.length - 1), H);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  ctx.strokeStyle = "#c8f135";
  ctx.lineWidth = 2;
  ctx.lineJoin = "round";
  ctx.lineCap = "round";
  data.forEach((v, i) => i === 0 ? ctx.moveTo(px(i), py(v)) : ctx.lineTo(px(i), py(v)));
  ctx.stroke();

  // Hover
  if(hoverIdx >= 0 && hoverIdx < data.length){
    const hx = px(hoverIdx), hy = py(data[hoverIdx]);
    ctx.beginPath();
    ctx.strokeStyle = "rgba(200,241,53,0.3)";
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.moveTo(hx, 0); ctx.lineTo(hx, H);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.beginPath();
    ctx.arc(hx, hy, 6, 0, Math.PI * 2);
    ctx.fillStyle = "#c8f135";
    ctx.fill();
    ctx.beginPath();
    ctx.arc(hx, hy, 3, 0, Math.PI * 2);
    ctx.fillStyle = "#0a0a0a";
    ctx.fill();
  }
}

function setRange(btn: HTMLElement) {
  document.querySelectorAll(".time-pill").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  currentRange = btn.dataset.range!;
  chartData = generateChartData(currentRange);
  drawChart(chartData);
  document.getElementById("chart-tooltip")!.style.display = "none";
}
(window as any).setRange = setRange;

canvas.addEventListener("mousemove", (e) => {
  const rect = canvas.getBoundingClientRect();
  const idx = Math.round(((e.clientX - rect.left) / rect.width) * (chartData.length - 1));
  const clamped = Math.max(0, Math.min(chartData.length - 1, idx));
  drawChart(chartData, clamped);
  const tt = document.getElementById("chart-tooltip")!;
  tt.style.display = "flex";
  document.getElementById("chart-tooltip-val")!.textContent = fmtShort(chartData[clamped] - chartData[0]);
});
canvas.addEventListener("mouseleave", () => {
  drawChart(chartData);
  document.getElementById("chart-tooltip")!.style.display = "none";
});

// ── Load dashboard data ───────────────────────────────────
async function loadDashboard() {
  try {
    const res = await fetch(`${API}/dashboard`);
    const json = await res.json();
    if(!json.success) return;
    const d = json.data;

    // Wallet value
    document.getElementById("wallet-value")!.textContent = fmt(d.totalNetWorth);
    const pct = d.defiBalance > 0 ? ((d.totalYieldEarned / d.defiBalance) * 100).toFixed(1) : "4.6";
    document.getElementById("wallet-change-val")!.textContent = `+${pct}%`;

    // Stats
    document.getElementById("s-today")!.textContent = fmt(d.yieldToday);
    document.getElementById("s-today-pct")!.textContent = `+${((d.yieldToday / (d.totalNetWorth||1)) * 100).toFixed(1)}% Today`;
    document.getElementById("s-unrealized")!.textContent = fmt(-d.yieldToday * 0.36);
    document.getElementById("s-unrealized-pct")!.textContent = `-${(0.36 * ((d.yieldToday / (d.totalNetWorth||1)) * 100)).toFixed(1)}% Today`;
    document.getElementById("s-projected")!.textContent = fmt(d.yieldMonth * 12);
    document.getElementById("s-projected-pct")!.textContent = `+${((d.yieldMonth * 12 / (d.totalNetWorth||1)) * 100).toFixed(1)}% Today`;
    document.getElementById("s-net")!.textContent = fmt(d.totalYieldEarned);
    document.getElementById("s-net-pct")!.textContent = `-${((d.yieldToday * 0.1 / (d.totalNetWorth||1)) * 100).toFixed(1)}% Today`;

    // Risk bar solid lime
    document.getElementById("risk-fill")!.style.width = "40%";

    // Transactions — 2-col grid, card per transaksi dengan sparkline
    const txns = d.recentDecisions.slice(0, 6);
    const icons: Record<string,string> = { rebalance:"⇄", deposit_suggestion:"↓", goal_forecast:"◎", risk_alert:"⚠" };
    const grid = document.getElementById("txn-grid")!;

    function genSpark(seed: number, count = 22): number[] {
      let v = 50 + seed * 9;
      return Array.from({length: count}, () => { v += (Math.random() - 0.47) * 10; return Math.max(5, Math.min(95, v)); });
    }
    function sparkPath(pts: number[], w: number, h: number): string {
      const mn = Math.min(...pts), mx = Math.max(...pts), rng = mx - mn || 1;
      return "M" + pts.map((v, i) => `${(i/(pts.length-1))*w},${h - ((v-mn)/rng)*h}`).join("L");
    }

    if(txns.length === 0) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;color:#555;font-size:0.8125rem;padding:24px;">No recent activity</div>`;
    } else {
      const padded = txns.length % 2 !== 0 ? [...txns, null] : txns;
      grid.innerHTML = padded.map((t: any, i: number) => {
        if(!t) return `<div class="txn-card" style="opacity:0;pointer-events:none;"></div>`;
        const isLime = i === 2;
        const spark = genSpark(i);
        const path = sparkPath(spark, 200, 52);
        const amount = t.expectedGain >= 0 ? `+${fmt(t.expectedGain)}` : fmt(t.expectedGain);
        const status = t.status === "executed" ? "confirmed" : t.status === "rejected" ? "failed" : "pending";
        const statusIcon = status === "confirmed" ? "✓" : status === "failed" ? "✕" : "◷";
        const typeLabel = t.type.replace(/_/g," ").replace(/\b\w/g, (c: string) => c.toUpperCase());
        const dateStr = new Date(t.createdAt).toLocaleDateString("en-US",{day:"2-digit",month:"2-digit",year:"numeric"});
        const strokeColor = isLime ? "rgba(0,0,0,0.25)" : "rgba(255,255,255,0.4)";        return `
          <div class="txn-card ${isLime ? "lime" : ""}">
            <div class="txn-top">
              <div class="txn-icon">
                ${icons[t.type]||"◎"}
              </div>
              <div class="txn-meta">
                <div class="txn-type">${typeLabel}</div>
                <div class="txn-date">${dateStr}</div>
              </div>
            </div>
            <div class="txn-spark">
              <svg viewBox="0 0 200 52" preserveAspectRatio="none">
                <path d="${path}" fill="none" stroke="${strokeColor}" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="txn-asset">${t.goalName}</div>
            <div class="txn-amount">${amount}</div>
            <div class="txn-status ${status}">${statusIcon} ${status.charAt(0).toUpperCase()+status.slice(1)}</div>
          </div>`;
      }).join("");
    }

    // Goals mini
    const goalsMini = document.getElementById("goals-mini")!;
    if(d.goalSummaries.length === 0) {
      goalsMini.innerHTML = `<div style="color:#555;font-size:0.8125rem;text-align:center;padding:16px;">No goals yet</div>`;
    } else {
      goalsMini.innerHTML = d.goalSummaries.map((g: any) => `
        <div class="goal-mini">
          <div class="goal-mini-top">
            <span class="goal-mini-name">${g.name}</span>
            <span class="goal-mini-pct">${g.progressPercent}%</span>
          </div>
          <div class="goal-mini-bar">
            <div class="goal-mini-fill" style="width:${g.progressPercent}%;"></div>
          </div>
        </div>`).join("");
    }

  } catch(err) {
    console.error("Dashboard load failed:", err);
  }
}

// Init
chartData = generateChartData(currentRange);
drawChart(chartData);
window.addEventListener("resize", () => drawChart(chartData));
loadDashboard();
</script>

</MainLayout>
