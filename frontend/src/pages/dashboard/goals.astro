---
import MainLayout from "../../layouts/MainLayout.astro";
import AutomationIsland from "../../components/goals/AutomationIsland.jsx";
---

<MainLayout title="Goals" activePage="goals">
<style>
  .goals-create-row { display: flex; gap: var(--s3); }
  @media (max-width: 480px) {
    .goals-create-row { flex-direction: column; }
    .goals-create-row .btn { width: 100%; }
  }
</style>
<div style="padding:28px 24px;">

  <div class="page-header">
    <h1 class="page-title">Goals</h1>
    <p class="page-subtitle">Set your goals once. Vyo handles the rest.</p>
  </div>

  <!-- Create Goal -->
  <div class="card-static" style="margin-bottom:var(--s6); background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r-lg); padding:var(--s6);">
    <div style="margin-bottom:var(--s3); font-size:var(--font-sm); font-weight:600; color:var(--text-primary);">
      Create a New Goal
    </div>
    <div class="goals-create-row">
      <input
        type="text"
        class="input"
        id="goal-input"
        placeholder='e.g. "Save $5,000 for a vacation by December"'
        style="flex:1;"
      />
      <button class="btn btn-primary btn-lg" id="create-goal-btn" onclick="createGoal()">
        Create
      </button>
    </div>
    <p style="margin-top:var(--s2); font-size:var(--font-xs); color:var(--text-muted);">
      Describe your goal in plain English — we'll figure out the amount, deadline, and vault strategy.
    </p>
  </div>

  <!-- Goals Grid -->
  <div class="goals-grid" id="goals-grid">
    <div class="card empty-state loading">
      <div class="empty-state-text">Loading goals...</div>
    </div>
  </div>

  <!-- Deposit Modal -->
  <div class="modal-overlay" id="deposit-modal">
    <div class="modal">
      <h3 class="modal-title">Deposit</h3>
      <p style="color:var(--text-secondary); margin-bottom:var(--s5); font-size:var(--font-sm);" id="deposit-goal-name"></p>
      <div class="input-group">
        <label class="input-label">Amount (USD)</label>
        <input type="number" class="input" id="deposit-amount" placeholder="500" min="1" />
      </div>
      <div style="display:flex; gap:var(--s3); justify-content:flex-end; margin-top:var(--s6);">
        <button class="btn btn-ghost" onclick="closeDepositModal()">Cancel</button>
        <button class="btn btn-primary" id="confirm-deposit-btn" onclick="confirmDeposit()">Confirm Deposit</button>
      </div>
    </div>
  </div>

  <!-- Automation Island -->
  <div id="automation-island-root" style="display:none;">
    <AutomationIsland client:only="react" />
  </div>

</div>
</MainLayout>

<script>
  const API = "/api";
  let currentGoalId: string | null = null;

  const fmt = (n: number) => new Intl.NumberFormat("en-US", { style: "currency", currency: "USD" }).format(n);
  const DOT_COLORS = ["#c8f135","#3b82f6","#a78bfa","#f59e0b","#06b6d4","#ef4444"];

  async function loadGoals() {
    try {
      const res = await fetch(`${API}/goals`);
      const json = await res.json();
      if (!json.success) return;

      const goals = json.data;
      const grid = document.getElementById("goals-grid")!;

      if (goals.length === 0) {
        grid.innerHTML = `
          <div class="card empty-state">
            <div class="empty-state-icon">◎</div>
            <div class="empty-state-text">No goals yet — create one above</div>
          </div>`;
        return;
      }

      grid.innerHTML = goals.map((g: any) => {
        const progress = Math.min(100, Math.round((g.currentAmount / g.targetAmount) * 100));
        return `
          <div class="card goal-card">
            <div class="goal-card-header">
              <div class="goal-name">${g.name}</div>
              <span class="goal-badge ${g.priority}">${g.priority}</span>
            </div>
            <div class="goal-progress-section">
              <div class="goal-amounts">
                <span class="goal-current">${fmt(g.currentAmount)}</span>
                <span class="goal-target">of ${fmt(g.targetAmount)}</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style="width:${progress}%;"></div>
              </div>
              <span class="goal-percent">${progress}%</span>
            </div>
            <div class="goal-allocations">
              ${g.vaultAllocations.map((a: any, i: number) => `
                <div class="allocation-row">
                  <span class="allocation-name">
                    <span class="allocation-dot" style="background:${DOT_COLORS[i % DOT_COLORS.length]};"></span>
                    ${a.vaultName} <span style="color:var(--text-muted);">${a.percentage}%</span>
                  </span>
                  <span class="allocation-value">${fmt(a.currentBalance)}</span>
                </div>`).join("")}
            </div>
            <div class="goal-deadline">
              Deadline: ${new Date(g.deadline).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
              · <span style="text-transform:capitalize;">${g.riskProfile}</span> risk
            </div>
            <div style="display:flex; gap:var(--s3); margin-top:var(--s5);">
              <button class="btn btn-primary" style="flex:1;" onclick="openDepositModal('${g.id}','${g.name.replace(/'/g,"\\'")}')">
                Deposit
              </button>
              <button class="btn btn-ghost" onclick="openAutomationSettings('${g.id}','${g.name.replace(/'/g,"\\'")}')" style="padding:var(--s2) var(--s3);">
                ⚙
              </button>
              <button class="btn btn-ghost" onclick="deleteGoal('${g.id}')" style="padding:var(--s2) var(--s3);">✕</button>
            </div>
            <div id="automation-mount-${g.id}"></div>
          </div>`;
      }).join("");
    } catch (err) {
      console.error("Failed to load goals:", err);
    }
  }

  async function createGoal() {
    const input = document.getElementById("goal-input") as HTMLInputElement;
    const text = input.value.trim();
    if (!text) { input.focus(); return; }

    const btn = document.getElementById("create-goal-btn") as HTMLButtonElement;
    btn.textContent = "Creating...";
    btn.disabled = true;

    try {
      const res = await fetch(`${API}/goals`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ input: text }),
      });
      const json = await res.json();
      if (json.success) { input.value = ""; loadGoals(); }
    } catch (err) {
      console.error("Failed to create goal:", err);
    } finally {
      btn.textContent = "Create";
      btn.disabled = false;
    }
  }

  document.getElementById("goal-input")?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter") createGoal();
  });

  function openDepositModal(goalId: string, goalName: string) {
    currentGoalId = goalId;
    document.getElementById("deposit-goal-name")!.textContent = `Depositing to: ${goalName}`;
    document.getElementById("deposit-modal")!.classList.add("open");
    (document.getElementById("deposit-amount") as HTMLInputElement).focus();
  }

  function closeDepositModal() {
    document.getElementById("deposit-modal")!.classList.remove("open");
    currentGoalId = null;
  }

  async function confirmDeposit() {
    const amount = parseFloat((document.getElementById("deposit-amount") as HTMLInputElement).value);
    if (!amount || amount <= 0 || !currentGoalId) return;

    const btn = document.getElementById("confirm-deposit-btn") as HTMLButtonElement;
    btn.textContent = "Processing...";
    btn.disabled = true;

    try {
      const res = await fetch(`${API}/transactions/deposit`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ goalId: currentGoalId, amount }),
      });
      const json = await res.json();
      if (json.success) { closeDepositModal(); loadGoals(); }
    } catch (err) {
      console.error("Deposit failed:", err);
    } finally {
      btn.textContent = "Confirm Deposit";
      btn.disabled = false;
    }
  }

  async function deleteGoal(id: string) {
    if (!confirm("Delete this goal?")) return;
    await fetch(`${API}/goals/${id}`, { method: "DELETE" });
    loadGoals();
  }

  function openAutomationSettings(goalId: string, goalName: string) {
    window.dispatchEvent(new CustomEvent('goal-automation', {
      detail: { goal: { id: goalId, name: goalName } }
    }));
  }

  // expose to inline onclick
  (window as any).createGoal = createGoal;
  (window as any).openDepositModal = openDepositModal;
  (window as any).closeDepositModal = closeDepositModal;
  (window as any).confirmDeposit = confirmDeposit;
  (window as any).deleteGoal = deleteGoal;
  (window as any).openAutomationSettings = openAutomationSettings;

  loadGoals();
</script>
