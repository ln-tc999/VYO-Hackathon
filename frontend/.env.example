# ============================================
# Vyo Apps - Environment Variables
# ============================================

# WalletConnect Project ID (Required)
# Get from https://cloud.walletconnect.com
PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id_here

# Chain Configuration
# 84532 = Base Sepolia Testnet (default)
# 8453 = Base Mainnet
PUBLIC_CHAIN_ID=84532

# Optional: Custom RPC URL (uses default if not set)
# For testnet: https://sepolia.base.org
# For mainnet: https://mainnet.base.org
# PUBLIC_RPC_URL=https://sepolia.base.org

# API Base URL
PUBLIC_API_BASE_URL=http://localhost:3001/api

# ============================================
# Testnet Resources
