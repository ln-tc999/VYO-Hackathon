# Vyo Apps Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# PRIVATE (DO NOT COMMIT)
# ===========================================
PRIVATE_KEY=0x...

# ===========================================
# CHAINLINKS AUTOMATION
# ===========================================
CHAINLINK_REGISTRY_ADDRESS=0x...

# ===========================================
# VYOROUTER
# ===========================================
VYOROUTER_ADDRESS=0x94B98209622EF89426dA8FCCa73BeA096AA43Ff5
YO_CHAIN_ID=84532

# ===========================================
# YO SDK
# ===========================================
DEV_MODE=mock  # Set to "live" for production

# ===========================================
# FRONTEND
# ===========================================
PUBLIC_WALLET_CONNECT_PROJECT_ID=your-project-id
PUBLIC_CHAIN_ID=84532
