{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", ".astro/**", "out/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "type-check": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$"],
            "outputs": []
        },
        "preview": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$"],
            "outputs": []
        },
        "fmt": {
            "cache": false
        },
        "lint": {
            "inputs": ["$TURBO_DEFAULT$"],
            "outputs": []
        },
        "clean": {
            "cache": false
        }
    }
}
